---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const items: [string, string][] = [
  ["1 Gbps fiber", "Fast fiber primary line with a redundant backup ISP. You're never offline."],
  ["24/7 keycard access", "Members come and go on their own schedule. App-based check-in."],
  ["Dedicated desks", "Locked, yours, always set up the way you like."],
  ["Hot desks", "Pick any free spot when you drop in."],
  ["Meeting room", "Bookable by the hour or in 4-hour and 8-hour blocks. Open to non-members too."],
  ["Classroom", "For workshops, training, and talks. Discounted rate from the second hour."],
  ["Gym membership", "Included with Hot Desk, Dedicated Desk, and Team plans. Local Prilep partner."],
  ["Backyard", "Outdoor workspace, the only one of its kind in Macedonia."],
  ["Real coffee", "Beans, grinder, machine, water. No capsules."],
  ["Kitchen", "Snacks, water, fridge, dishwasher, kettle."],
  ["Quiet upper floor", "Phone calls and meetings happen downstairs or in booked rooms."],
  ["Member events", "Talks, workshops, after-work get-togethers. Members get priority."],
  ["Lockers", "Lock-up your laptop and gear. Dedicated members get personal storage."],
  ["Printer & scanner", "When the analog still matters."],
  ["Free street parking", "On all sides of the building."],
  ["Bilingual (EN / MK)", "Site, contracts, and onboarding in both languages."],
];

const phase2: [string, string][] = [
  ["Soundproof phone booth", "For uninterrupted calls without leaving the floor. ~€2,000 per unit."],
  ["UPS + backup generator", "Keep WiFi and lights running through outages. ~€1,500–€2,500."],
  ["Virtual business address", "Use the space's address for company registration and mail."],
];
---

<BaseLayout
  current="amenities"
  title="Amenities — Coworking Prilep"
  description="Everything that comes with a Coworking Prilep membership: 1 Gbps fiber, gym membership, classroom, backyard, member events, 24/7 access, and more."
>
  <PageHero
    eyebrow="Amenities"
    title="Everything you need to actually work."
    subtitle="A coworking space is more than desks. Here's what comes with every membership, plus what's coming in Phase 2."
  />

  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div data-anim="rise" class="mb-12 max-w-2xl">
        <div class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
          At launch
        </div>
        <h2 class="font-display text-4xl leading-[0.95] uppercase md:text-5xl">
          What's included.
        </h2>
      </div>
      <div
        data-anim="rise-stagger"
        class="grid gap-px bg-bone/10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          items.map(([title, body]) => (
            <div class="group bg-ink p-8 transition-colors hover:bg-steel-900">
              <div class="font-display text-2xl uppercase">{title}</div>
              <div class="mt-3 text-sm leading-relaxed text-bone/65">{body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div data-anim="rise" class="mb-12 max-w-2xl">
        <div class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
          Phase 2
        </div>
        <h2 class="font-display text-4xl leading-[0.95] uppercase md:text-5xl">
          Coming next.
        </h2>
        <p class="mt-4 text-bone/65">
          Honest about what's confirmed and what isn't. These are on our list once we're a few months in and the numbers support the investment.
        </p>
      </div>
      <div
        data-anim="rise-stagger"
        class="grid gap-px bg-bone/10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          phase2.map(([title, body]) => (
            <div class="group bg-ink p-8 transition-colors hover:bg-steel-900">
              <div class="font-mono text-[10px] tracking-[0.3em] text-rust uppercase mb-2">
                Planned
              </div>
              <div class="font-display text-2xl uppercase">{title}</div>
              <div class="mt-3 text-sm leading-relaxed text-bone/65">{body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-3xl text-center" data-anim="rise">
      <div class="mb-6 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
        Missing something?
      </div>
      <h2 class="font-display text-3xl uppercase md:text-5xl">
        Tell us what matters.
      </h2>
      <p class="mx-auto mt-8 max-w-xl text-bone/70">
        Before we lock the final amenity list, we want to know what would actually make you join. Drop us a line.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block bg-rust px-10 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
