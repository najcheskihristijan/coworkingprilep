---
const year = new Date().getFullYear();
---

<footer class="border-t border-bone/10 bg-ink">
  <div
    class="mx-auto grid max-w-7xl gap-12 px-6 py-20 md:grid-cols-4 md:px-12 md:py-24"
  >
    <div class="md:col-span-2">
      <div class="font-display text-5xl leading-[0.9] uppercase md:text-6xl">
        Coworking<br />
        <span class="text-rust">Prilep</span>
      </div>
      <p class="mt-6 max-w-md text-bone/60">
        The first coworking space in Prilep, North Macedonia. Built
        for remote workers, freelancers, and small teams. Opening 2026.
      </p>
      <div class="mt-8 flex items-center gap-4">
        <span class="font-mono text-[10px] tracking-[0.35em] text-bone/40 uppercase">
          Follow
        </span>
        <a
          href="https://www.instagram.com/coworkingprilep/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Coworking Prilep on Instagram"
          class="text-bone/60 hover:text-rust transition-colors"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
            <rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4.3" /><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://www.facebook.com/people/Coworking-Prilep/61590212716736/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Coworking Prilep on Facebook"
          class="text-bone/60 hover:text-rust transition-colors"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
            <circle cx="12" cy="12" r="9" /><text x="12.4" y="16.7" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="currentColor" stroke="none">f</text>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/cws-coworking-prilep/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Coworking Prilep on LinkedIn"
          class="text-bone/60 hover:text-rust transition-colors"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
            <rect x="3" y="3" width="18" height="18" rx="2" /><text x="12" y="16.3" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="700" fill="currentColor" stroke="none">in</text>
          </svg>
        </a>
      </div>
    </div>

    <div>
      <div
        class="mb-5 font-mono text-[10px] tracking-[0.35em] text-bone/40 uppercase"
      >
        Site
      </div>
      <ul class="space-y-3 text-sm text-bone/75">
        <li><a class="hover:text-rust transition-colors" href="/blog">Blog</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">About</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">Space</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">Amenities</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">Pricing</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">FAQ</a></li>
        <li><a class="hover:text-rust transition-colors" href="/coming-soon">Contact</a></li>
      </ul>
    </div>

    <div>
      <div
        class="mb-5 font-mono text-[10px] tracking-[0.35em] text-bone/40 uppercase"
      >
        Contact
      </div>
      <ul class="space-y-3 text-sm text-bone/75">
        <li>
          <a
            class="hover:text-rust transition-colors"
            href="mailto:coworkingprilep@outlook.com"
          >
            coworkingprilep@outlook.com
          </a>
        </li>
        <li>Prilep, North Macedonia</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-bone/10">
    <div
      class="mx-auto flex max-w-7xl flex-col justify-between gap-3 px-6 py-6 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase md:flex-row md:px-12"
    >
      <div>© {year} Coworking Prilep</div>
      <div class="flex flex-wrap gap-5">
        <a class="hover:text-rust transition-colors" href="/privacy">Privacy</a>
        <a class="hover:text-rust transition-colors" href="/refunds">Refunds</a>
        <a class="hover:text-rust transition-colors" href="/delivery">Delivery</a>
      </div>
      <div>Built in Prilep <span class="text-rust">●</span> Opening 2026</div>
    </div>
  </div>
</footer>
