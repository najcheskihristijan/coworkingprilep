---
// Decorative horizontal chain — drawn programmatically.
// Alternating vertical / horizontal links, stroke-based so it
// can animate via stroke-dasharray on scroll.

interface Props {
  links?: number;
  class?: string;
}

const { links = 18, class: className = "" } = Astro.props;

const linkW = 70; // bounding box per link
const linkH = 70;
const totalW = links * linkW * 0.6 + linkW * 0.4;
const cy = linkH / 2;
---

<svg
  class={`chain-svg ${className}`}
  viewBox={`0 0 ${totalW} ${linkH}`}
  preserveAspectRatio="xMinYMid meet"
  fill="none"
  stroke="currentColor"
  stroke-width="3"
  aria-hidden="true"
>
  {
    Array.from({ length: links }).map((_, i) => {
      const cx = linkW * 0.4 + i * linkW * 0.6;
      const vertical = i % 2 === 0;
      const rx = vertical ? 14 : 24;
      const ry = vertical ? 24 : 14;
      return (
        <ellipse
          cx={cx}
          cy={cy}
          rx={rx}
          ry={ry}
          class="chain-link"
          style={`--i:${i}`}
        />
      );
    })
  }
</svg>

<style>
  .chain-svg .chain-link {
    opacity: 0;
    transform-origin: center;
    transform: scale(0.7);
    transition:
      opacity 0.5s ease,
      transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: calc(var(--i) * 0.04s);
  }
  .chain-svg.is-revealed .chain-link {
    opacity: 1;
    transform: scale(1);
  }
</style>
