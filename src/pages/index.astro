---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChainSvg from "../components/ChainSvg.astro";
---

<BaseLayout current="home" hideFooter={true}>
  <!-- ────────────────────────── HERO ────────────────────────── -->
  <section
    class="relative flex min-h-screen flex-col justify-end overflow-hidden bg-ink px-6 pt-32 pb-16 md:px-12 md:pt-40 md:pb-24"
  >
    <!-- Drifting blueprint grid -->
    <div class="hero-grid z-0"></div>

    <!-- Background glow shapes -->
    <div class="pointer-events-none absolute inset-0 z-0">
      <div
        class="glow-pulse absolute top-1/4 -right-32 h-[70vh] w-[70vh] bg-rust/15 blur-[120px]"
      >
      </div>
      <div
        class="absolute bottom-0 -left-32 h-[60vh] w-[60vh] bg-bone/5 blur-[120px]"
      >
      </div>
    </div>

    <!-- Side rail -->
    <div
      class="absolute top-0 bottom-0 left-6 z-10 hidden w-px bg-gradient-to-b from-transparent via-bone/15 to-transparent md:left-12 md:block"
    >
    </div>

    <!-- Live status badge -->
    <div
      class="absolute top-24 right-6 z-20 flex items-center gap-3 font-mono text-[10px] tracking-[0.35em] text-bone/70 uppercase reveal-fade md:top-28 md:right-12"
      style="animation-delay: 1.5s;"
    >
      <span class="dot-blink inline-block h-2 w-2 rounded-full bg-rust"></span>
      <span>Opening 2026</span>
    </div>

    <!-- Red horizontal sweep line -->
    <div
      class="sweep-line absolute top-[42%] right-0 left-0 z-0 h-px bg-rust/70"
    >
    </div>

    <div class="relative z-10 max-w-6xl">
      <!-- Eyebrow -->
      <div class="mb-8">
        <p
          class="reveal-up inline-flex items-center gap-3 font-mono text-xs tracking-[0.35em] text-rust uppercase"
          style="animation-delay: 0.6s;"
        >
          <span class="inline-block h-px w-8 bg-rust"></span>
          The first coworking space in Prilep
        </p>
      </div>

      <!-- Hero title with line-by-line mask reveal -->
      <h1
        class="font-display text-[clamp(4.5rem,16vw,15rem)] leading-[0.82] tracking-tight uppercase"
      >
        <span class="mask-wrap">
          <span class="mask-inner" style="animation-delay: 0.85s;">
            Coworking
          </span>
        </span>
        <span class="mask-wrap">
          <span
            class="mask-inner text-rust"
            style="animation-delay: 1.05s;"
          >
            Prilep
          </span>
        </span>
      </h1>

      <!-- Tagline -->
      <p
        class="reveal-up mt-10 max-w-xl text-base leading-relaxed text-bone/75 md:text-lg"
        style="animation-delay: 1.5s;"
      >
        300m² across two floors. Dedicated desks, meeting rooms,
        community. Built for remote workers, freelancers, and small
        teams in Prilep, North Macedonia.
      </p>

      <!-- Email capture (hero) -->
      <form
        data-prelaunch-form
        id="subscribe"
        class="reveal-up mt-12 flex w-full max-w-md flex-col items-stretch border border-bone/25 transition-colors hover:border-bone/50 sm:flex-row"
        style="animation-delay: 1.7s;"
        method="POST"
        action="#"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 bg-transparent px-5 py-4 text-sm text-bone placeholder-bone/35 focus:outline-none"
        />
        <button
          type="submit"
          class="bg-rust px-6 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
        >
          Notify me
        </button>
      </form>

      <p
        class="reveal-up mt-4 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase"
        style="animation-delay: 1.9s;"
      >
        Be the first to know when we open
      </p>
    </div>

    <!-- Scroll cue -->
    <div
      class="reveal-fade absolute right-6 bottom-6 z-10 hidden flex-col items-center gap-3 md:right-12 md:bottom-10 md:flex"
      style="animation-delay: 2.1s;"
    >
      <div
        class="font-mono text-[10px] tracking-[0.35em] text-bone/40 uppercase"
      >
        Scroll
      </div>
      <div class="scroll-line h-14 w-px bg-bone/10"></div>
    </div>
  </section>

  <!-- ────────────────────────── MARQUEE ────────────────────────── -->
  <section
    class="overflow-hidden border-y border-bone/10 bg-ink whitespace-nowrap"
  >
    <div
      class="animate-marquee flex items-center py-6 font-mono text-xs tracking-[0.35em] text-bone/45 uppercase"
    >
      {
        Array.from({ length: 2 }).map(() => (
          <>
            <span class="mx-10">Coworking Prilep</span>
            <span class="mx-10 text-rust">●</span>
            <span class="mx-10">300m²</span>
            <span class="mx-10 text-rust">●</span>
            <span class="mx-10">Two floors</span>
            <span class="mx-10 text-rust">●</span>
            <span class="mx-10">Opening 2026</span>
            <span class="mx-10 text-rust">●</span>
            <span class="mx-10">Prilep — North Macedonia</span>
            <span class="mx-10 text-rust">●</span>
            <span class="mx-10">Industrial. Modern. Local.</span>
            <span class="mx-10 text-rust">●</span>
          </>
        ))
      }
    </div>
  </section>

  <!-- ────────────────────────── BUILT FOR THE WAY YOU WORK ────────────────────────── -->
  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-3">
      <div class="md:col-span-1" data-anim="rise">
        <div
          class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
        >
          01 — The space
        </div>
        <h2 class="font-display text-4xl leading-[0.95] uppercase md:text-5xl">
          Built for the<br />way you work.
        </h2>
      </div>
      <div class="md:col-span-2" data-anim="rise">
        <p class="text-lg leading-relaxed text-bone/75">
          Two floors. Dedicated desks. Meeting room, a quiet upper
          level, a backyard, a kitchen, fast internet, strong coffee.
          Whether you're a remote employee, a freelancer, or a small
          team, we built this for you, with the people of Prilep in
          mind.
        </p>
        <div
          data-anim="rise-stagger"
          class="mt-10 grid grid-cols-2 gap-x-8 gap-y-6 md:grid-cols-4"
        >
          <div>
            <div
              data-anim="count"
              data-to="300"
              data-suffix=""
              class="font-display text-4xl text-rust md:text-5xl"
            >
              0
            </div>
            <div
              class="mt-1 font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
            >
              m² total
            </div>
          </div>
          <div>
            <div
              data-anim="count"
              data-to="20"
              data-suffix="+"
              class="font-display text-4xl text-rust md:text-5xl"
            >
              0
            </div>
            <div
              class="mt-1 font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
            >
              Desks
            </div>
          </div>
          <div>
            <div
              data-anim="count"
              data-to="2"
              data-suffix=""
              class="font-display text-4xl text-rust md:text-5xl"
            >
              0
            </div>
            <div
              class="mt-1 font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
            >
              Floors
            </div>
          </div>
          <div>
            <div class="font-display text-4xl text-rust md:text-5xl">1st</div>
            <div
              class="mt-1 font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
            >
              In Prilep
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────────────────── CHAIN ────────────────────────── -->
  <section class="overflow-hidden border-b border-bone/10 py-16 md:py-20">
    <div data-anim="reveal-chain" class="text-bone/30">
      <ChainSvg links={20} class="block h-16 w-full md:h-24" />
    </div>
    <div class="mt-2 px-6 text-center md:px-12">
      <p
        class="font-mono text-sm tracking-[0.4em] text-bone/55 uppercase md:text-base"
      >
        Linked by work <span class="text-rust">●</span> bound by place
      </p>
    </div>
  </section>

  <!-- ────────────────────────── PINNED MANIFESTO ────────────────────────── -->
  <section
    data-anim="scrub-manifesto"
    class="relative flex h-screen items-center overflow-hidden border-b border-bone/10 px-6 md:px-12"
  >
    <div class="mx-auto max-w-5xl">
      <div
        class="mb-12 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
      >
        02 — Why
      </div>
      <div
        class="font-display text-3xl leading-[1.05] uppercase md:text-6xl"
      >
        <div data-manifesto-line class="py-2">
          Because work doesn't need to happen at home.
        </div>
        <div data-manifesto-line class="py-2">
          Because cafés get loud, and offices get expensive.
        </div>
        <div data-manifesto-line class="py-2">
          Because <span class="text-rust">Prilep</span> deserves a place to work.
        </div>
        <div data-manifesto-line class="py-2">
          One that's modern. Local. Built for us.
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────────────────── WHAT YOU GET ────────────────────────── -->
  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div data-anim="rise" class="mb-16">
        <div
          class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
        >
          03 — What you get
        </div>
        <h2 class="font-display text-4xl leading-[0.95] uppercase md:text-5xl">
          More than a desk.
        </h2>
      </div>
      <div
        data-anim="rise-stagger"
        class="grid gap-px bg-bone/10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          [
            ["Dedicated desks", "Yours. Locked. Always ready."],
            ["Hot desks", "Drop in. Pick a spot. Get to work."],
            ["Meeting room", "A meeting room for you and your teammates when you need it."],
            ["Kitchen", "Real coffee. Snacks. A place to break."],
            ["Backyard", "Outdoor space when the weather's right."],
            ["Fast internet", "Fiber, redundant, with a backup line."],
            ["Community", "People doing the same thing as you."],
            ["Events", "Talks. Workshops. After-work."],
            ["24/7 access", "Coming for dedicated members."],
          ].map(([title, body]) => (
            <div class="group bg-ink p-8 transition-colors hover:bg-steel-900">
              <div class="font-display text-2xl uppercase">{title}</div>
              <div class="mt-3 text-sm leading-relaxed text-bone/60">{body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ────────────────────────── CTA STRIP ────────────────────────── -->
  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-5xl text-center">
      <div
        data-anim="rise"
        class="mb-6 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
      >
        Be early
      </div>
      <h2
        data-anim="rise"
        class="font-display text-[clamp(2.5rem,8vw,7rem)] leading-[0.9] uppercase"
      >
        Save your seat<br />before we open.
      </h2>
      <p
        data-anim="rise"
        class="mx-auto mt-8 max-w-xl text-bone/70"
      >
        We'll let early subscribers in first when we open the doors.
        No spam. Just one email when we go live.
      </p>

      <form
        data-prelaunch-form
        data-anim="rise"
        class="mx-auto mt-12 flex w-full max-w-md flex-col items-stretch border border-bone/25 transition-colors hover:border-bone/50 sm:flex-row"
        method="POST"
        action="#"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 bg-transparent px-5 py-4 text-sm text-bone placeholder-bone/35 focus:outline-none"
        />
        <button
          type="submit"
          class="bg-rust px-6 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
        >
          Notify me
        </button>
      </form>
    </div>
  </section>

  <script>
    // Pre-launch email capture → Supabase Edge Function `subscribe`.
    // The function inserts into the `subscribers` table AND sends a thank-you
    // email via Resend. Keeping the Resend API key server-side.
    const SUPABASE_URL = "https://iikrjwnwejliupiwrnpy.supabase.co";
    const SUPABASE_PUBLISHABLE_KEY =
      "sb_publishable_ARIm4r9R-t0YCn-W91A6yw_qRuMm1Ra";
    const SUBSCRIBE_ENDPOINT = `${SUPABASE_URL}/functions/v1/subscribe`;

    document
      .querySelectorAll<HTMLFormElement>("[data-prelaunch-form]")
      .forEach((form) => {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const button = form.querySelector<HTMLButtonElement>(
            'button[type="submit"]',
          );
          const input = form.querySelector<HTMLInputElement>(
            'input[name="email"]',
          );
          if (!input || !button) return;

          const originalText = button.textContent;
          const email = input.value.trim().toLowerCase();
          if (!email) return;

          button.disabled = true;
          button.textContent = "Sending…";

          const showMessage = (text: string) => {
            form.innerHTML = `<div class="w-full px-5 py-4 text-sm tracking-wide text-bone">${text}</div>`;
          };

          try {
            const res = await fetch(SUBSCRIBE_ENDPOINT, {
              method: "POST",
              headers: {
                Authorization: `Bearer ${SUPABASE_PUBLISHABLE_KEY}`,
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ email, source: "website" }),
            });

            const data = await res.json().catch(() => ({}));

            if (res.ok && data.duplicate) {
              showMessage(
                "You&rsquo;re already on the list. We&rsquo;ll be in touch.",
              );
            } else if (res.ok) {
              // GA conversion event — only fires when consent is granted.
              const w = window as any;
              if (typeof w.gtag === "function") {
                w.gtag("event", "subscribe", {
                  source: "website_prelaunch",
                });
                // GA4's recommended lead event, for the "Conversions" report.
                w.gtag("event", "generate_lead", {
                  method: "website_prelaunch",
                });
              }
              showMessage(
                "You&rsquo;re on the list. Check your inbox for a welcome note.",
              );
            } else {
              console.error("[subscribe]", res.status, data);
              button.disabled = false;
              button.textContent = originalText;
              alert("Something went wrong. Please try again.");
            }
          } catch (err) {
            console.error("[subscribe]", err);
            button.disabled = false;
            button.textContent = originalText;
            alert("Network error. Please try again.");
          }
        });
      });
  </script>
</BaseLayout>
