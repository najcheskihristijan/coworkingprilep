---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const formatter = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<BaseLayout
  current="blog"
  title="Blog — Coworking Prilep"
  description="Notes, updates, and stories from the team building the first coworking space in Prilep, North Macedonia."
>
  <section class="px-6 pt-32 pb-16 md:px-12 md:pt-40 md:pb-24">
    <div class="mx-auto max-w-5xl">
      <div class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
        The blog
      </div>
      <h1 class="font-display text-5xl leading-[0.95] uppercase md:text-7xl">
        Notes from<br />the build.
      </h1>
      <p class="mt-6 max-w-xl text-bone/70">
        Renovation milestones, design decisions, the small wins, and the
        things we learn building Coworking Prilep.
      </p>
    </div>
  </section>

  {posts.length === 0 ? (
    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <div class="mb-6 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
          Coming soon
        </div>
        <h2 class="font-display text-3xl uppercase md:text-5xl">
          First post on the way.
        </h2>
        <p class="mt-6 text-bone/70">
          We&rsquo;ll start writing here once the renovation is underway. Want
          a heads-up?
        </p>
        <a
          href="/#subscribe"
          class="mt-10 inline-block bg-rust px-10 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
        >
          Join the list
        </a>
      </div>
    </section>
  ) : (
    <section class="border-t border-bone/10 px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-px bg-bone/10">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block bg-ink p-8 transition-colors hover:bg-steel-900 md:p-12"
            >
              <div class="font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
                {formatter.format(post.data.publishDate)}
              </div>
              <h2 class="mt-4 font-display text-3xl leading-[0.95] uppercase transition-colors group-hover:text-rust md:text-5xl">
                {post.data.title}
              </h2>
              <p class="mt-4 max-w-2xl text-bone/70">
                {post.data.description}
              </p>
              <div class="mt-6 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase group-hover:text-rust">
                Read &rarr;
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
