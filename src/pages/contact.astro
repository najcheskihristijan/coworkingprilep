---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  current="contact"
  title="Contact — Coworking Prilep"
  description="Get in touch with the Coworking Prilep team."
>
  <PageHero
    eyebrow="Contact"
    title="Talk to us."
    subtitle="Questions about membership, tours, partnerships, or events? We're here."
  />

  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto grid max-w-6xl gap-16 md:grid-cols-2">
      <div data-anim="rise">
        <div
          class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
        >
          Direct
        </div>
        <h2 class="font-display text-3xl uppercase md:text-4xl">
          The fastest way.
        </h2>
        <p class="mt-6 text-bone/75">
          Email is the best way to reach us. We answer within
          one business day.
        </p>
        <a
          href="mailto:coworkingprilep@outlook.com"
          class="mt-8 inline-block font-display text-2xl text-rust transition-colors hover:text-bone md:text-3xl"
        >
          coworkingprilep@outlook.com
        </a>
        <div class="mt-12 space-y-4 text-sm text-bone/70">
          <div>
            <div
              class="mb-1 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase"
            >
              Where
            </div>
            <div>Prilep, North Macedonia</div>
          </div>
          <div>
            <div
              class="mb-1 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase"
            >
              Opening
            </div>
            <div>2026</div>
          </div>
        </div>
      </div>

      <div data-anim="rise">
        <div
          class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase"
        >
          Or
        </div>
        <h2 class="font-display text-3xl uppercase md:text-4xl">
          Send a message.
        </h2>
        <form
          class="mt-8 space-y-5"
          method="POST"
          action="#"
        >
          <div>
            <label
              class="mb-2 block font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
              for="name"
            >
              Name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="w-full border border-bone/25 bg-transparent px-4 py-3 text-sm focus:border-rust focus:outline-none"
            />
          </div>
          <div>
            <label
              class="mb-2 block font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
              for="email"
            >
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full border border-bone/25 bg-transparent px-4 py-3 text-sm focus:border-rust focus:outline-none"
            />
          </div>
          <div>
            <label
              class="mb-2 block font-mono text-[10px] tracking-[0.3em] text-bone/50 uppercase"
              for="message"
            >
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full border border-bone/25 bg-transparent px-4 py-3 text-sm focus:border-rust focus:outline-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-rust px-8 py-3 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
          >
            Send message
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
