---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollAnimations from "../components/ScrollAnimations.astro";
import ConsentBanner from "../components/ConsentBanner.astro";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  current?:
    | "home"
    | "about"
    | "space"
    | "amenities"
    | "pricing"
    | "faq"
    | "contact"
    | "blog";
  hideHeader?: boolean;
  hideFooter?: boolean;
  noindex?: boolean;
  prelaunch?: boolean;
}

const {
  title = "Coworking Prilep — First Coworking Space in North Macedonia",
  description = "Dedicated desks, hot desks, meeting room, classroom, gym membership, fast fiber, backyard. The first coworking space in Prilep, MK. Opening 2026.",
  ogType = "website",
  current = "home",
  hideHeader = false,
  hideFooter = false,
  noindex = false,
  prelaunch = true,
} = Astro.props;

// Auto-noindex any /draft/* page so search engines never crawl unfinished content.
const isDraft = Astro.url.pathname.startsWith("/draft");
const shouldNoIndex = noindex || isDraft;

// Per-page canonical + og:url. Falls back to root for the dev server.
const siteOrigin =
  Astro.site?.toString().replace(/\/$/, "") ?? "https://coworkingprilep.mk";
const canonicalUrl = `${siteOrigin}${Astro.url.pathname.replace(/\/$/, "") || "/"}`;

// Microsoft Clarity (free session replay + heatmaps).
// Paste your Clarity project ID here (clarity.microsoft.com → Settings → Overview).
// Leave empty to disable — nothing loads until an ID is set.
const CLARITY_ID = "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Coworking Prilep" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://coworkingprilep.mk/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Coworking Prilep — the first coworking space in Prilep, North Macedonia. Opening 2026." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://coworkingprilep.mk/og-image.png" />
    <meta name="theme-color" content="#000000" />
    {shouldNoIndex && (
      <meta name="robots" content="noindex, nofollow" />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {!isDraft && (
      <>
        <script
          async
          is:inline
          src="https://www.googletagmanager.com/gtag/js?id=G-YDCX2P736Y"
        ></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () {
            window.dataLayer.push(arguments);
          };
          // Consent Mode v2 — default everything to denied until the user accepts.
          // GA4 still emits cookieless pings, so aggregate pageview counts survive.
          gtag("consent", "default", {
            analytics_storage: "denied",
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
            wait_for_update: 500,
          });
          gtag("js", new Date());
          gtag("config", "G-YDCX2P736Y");
        </script>
      </>
    )}
    {!isDraft && CLARITY_ID && (
      <script is:inline set:html={`
        // Microsoft Clarity loader. Cookie use is gated on consent: enable
        // "Cookie consent" in the Clarity dashboard, and the ConsentBanner calls
        // clarity("consent") on accept (mirrors the GA consent flow above).
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "${CLARITY_ID}");
      `} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="grain">
    {!hideHeader && <Header current={current} prelaunch={prelaunch && !isDraft} />}
    {isDraft && (
      <div class="bg-rust text-bone font-mono text-[10px] tracking-[0.3em] uppercase text-center py-2 px-4">
        Draft preview &middot; not indexed &middot;
        <a href="/draft" class="underline ml-2">All drafts</a>
      </div>
    )}
    <slot />
    {!hideFooter && <Footer />}
    {!isDraft && <ConsentBanner />}
    <ScrollAnimations />
  </body>
</html>
