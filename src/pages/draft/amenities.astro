---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { Icon } from "astro-icon/components";

const items: [string, string, string][] = [
  ["lucide:wifi-high", "1 Gbps fiber", "Fast fiber primary line with a redundant backup ISP. You're never offline."],
  ["lucide:key-round", "24/7 keycard access", "Members come and go on their own schedule. App-based check-in."],
  ["lucide:armchair", "Dedicated desks", "Locked, yours, always set up the way you like."],
  ["lucide:laptop", "Hot desks", "Pick any free spot when you drop in."],
  ["lucide:users", "Meeting room", "Bookable by the hour or in 4-hour and 8-hour blocks. Open to non-members too."],
  ["lucide:graduation-cap", "Classroom", "For workshops, training, and talks. Discounted rate from the second hour."],
  ["lucide:dumbbell", "Gym membership", "Included with Hot Desk, Dedicated Desk, and Team plans. Local Prilep partner."],
  ["lucide:trees", "Backyard", "Outdoor workspace or chillplace, you decide."],
  ["lucide:coffee", "Real coffee", "Beans, grinder, machine, water. No capsules."],
  ["lucide:utensils-crossed", "Kitchen", "Snacks, water, fridge, dishwasher, kettle."],
  ["lucide:volume-x", "Quiet upper floor", "Phone calls and meetings happen downstairs or in booked rooms."],
  ["lucide:calendar-days", "Member events", "Talks, workshops, after-work get-togethers. Members get priority."],
  ["lucide:lock", "Lockers", "Lock-up your laptop and gear. Dedicated members get personal storage."],
  ["lucide:printer", "Printer & scanner", "When the analog still matters."],
  ["lucide:square-parking", "Free street parking", "On all sides of the building."],
];
---

<BaseLayout
  current="amenities"
  title="Amenities — Coworking Prilep"
  description="Everything that comes with a Coworking Prilep membership: 1 Gbps fiber, gym membership, classroom, backyard, member events, 24/7 access, and more."
>
  <PageHero
    eyebrow="Amenities"
    title="Everything you need to actually work."
    subtitle="A coworking space is more than desks. Here's what comes with every membership."
  />

  <section class="border-b border-bone/10 px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div data-anim="rise" class="mb-12 max-w-2xl">
        <div class="mb-4 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
          Included
        </div>
        <h2 class="font-display text-4xl leading-[0.95] uppercase md:text-5xl">
          What you get.
        </h2>
      </div>
      <div
        data-anim="rise-stagger"
        class="grid gap-px bg-bone/10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          items.map(([iconName, title, body]) => (
            <div class="group bg-ink p-8 transition-colors hover:bg-steel-900">
              <Icon
                name={iconName}
                class="icon-cws mb-5 h-7 w-7 text-rust transition-transform group-hover:scale-110"
              />
              <div class="font-display text-2xl uppercase">{title}</div>
              <div class="mt-3 text-sm leading-relaxed text-bone/65">{body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-3xl text-center" data-anim="rise">
      <div class="mb-6 font-mono text-[10px] tracking-[0.35em] text-rust uppercase">
        Missing something?
      </div>
      <h2 class="font-display text-3xl uppercase md:text-5xl">
        Tell us what matters.
      </h2>
      <p class="mx-auto mt-8 max-w-xl text-bone/70">
        Before we lock the final amenity list, we want to know what would actually make you join. Drop us a line.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block bg-rust px-10 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
