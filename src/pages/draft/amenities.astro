---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const items = [
  ["Fast fiber internet", "Redundant backup line so you're never offline."],
  ["Dedicated desks", "Locked, yours, always set up the way you like."],
  ["Hot desks", "Pick any free spot when you drop in."],
  ["Meeting room", "Book it for calls, interviews, workshops."],
  ["Real coffee", "No capsules. Beans, grinder, machine, water."],
  ["Snacks & water", "Stocked kitchen, always."],
  ["Backyard", "Outdoor space for breaks and warm-weather work."],
  ["Quiet upper floor", "Rules-protected silent zone."],
  ["Printer & scanner", "When the analog still matters."],
  ["Whiteboard walls", "Think out loud. Plan in big."],
  ["Events space", "Talks, workshops, after-work."],
];
---

<BaseLayout
  current="amenities"
  title="Amenities — Coworking Prilep"
  description="What you get when you walk in: internet, coffee, meeting rooms, community."
>
  <PageHero
    eyebrow="Amenities"
    title="Everything you need to actually work."
    subtitle="A coworking space is more than desks. Here's what comes with every membership."
  />

  <section class="px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div
        data-anim="rise-stagger"
        class="grid gap-px bg-bone/10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          items.map(([title, body]) => (
            <div class="group bg-ink p-8 transition-colors hover:bg-steel-900">
              <div class="font-display text-2xl uppercase">{title}</div>
              <div class="mt-3 text-sm leading-relaxed text-bone/60">{body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
