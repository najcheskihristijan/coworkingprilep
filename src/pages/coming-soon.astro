---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  current="home"
  title="Coming soon — Coworking Prilep"
  description="This page is being built. The full site goes live when Coworking Prilep opens in 2026."
>
  <section
    class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-ink px-6 py-24 text-center md:px-12"
  >
    <!-- Drifting blueprint grid -->
    <div class="hero-grid z-0"></div>

    <!-- Background glow -->
    <div class="pointer-events-none absolute inset-0 z-0">
      <div
        class="glow-pulse absolute top-1/2 left-1/2 h-[60vh] w-[60vh] -translate-x-1/2 -translate-y-1/2 bg-rust/10 blur-[120px]"
      >
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl">
      <div
        class="reveal-up mb-8 inline-flex items-center gap-3 font-mono text-xs tracking-[0.35em] text-rust uppercase"
        style="animation-delay: 0.2s;"
      >
        <span class="inline-block h-px w-8 bg-rust"></span>
        Page coming soon
      </div>

      <h1
        class="font-display text-[clamp(4rem,12vw,10rem)] leading-[0.85] tracking-tight uppercase"
      >
        <span class="mask-wrap">
          <span class="mask-inner" style="animation-delay: 0.4s;">
            Coming
          </span>
        </span>
        <span class="mask-wrap">
          <span class="mask-inner text-rust" style="animation-delay: 0.6s;">
            Soon
          </span>
        </span>
      </h1>

      <p
        class="reveal-up mx-auto mt-10 max-w-xl text-base leading-relaxed text-bone/70 md:text-lg"
        style="animation-delay: 1.0s;"
      >
        This page is being built. The full site goes live when we open
        the doors in 2026. Join the list and we&rsquo;ll let you know
        the moment it&rsquo;s ready.
      </p>

      <a
        href="/#subscribe"
        class="reveal-up mt-12 inline-block bg-rust px-10 py-4 font-mono text-[11px] font-bold tracking-[0.25em] text-bone uppercase transition-colors hover:bg-rust-deep"
        style="animation-delay: 1.2s;"
      >
        Join the list
      </a>

      <div
        class="reveal-up mt-8 font-mono text-[10px] tracking-[0.3em] text-bone/40 uppercase"
        style="animation-delay: 1.4s;"
      >
        <a href="/" class="hover:text-rust transition-colors">
          ← Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
